<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6">
  <diagram name="Сторінка-1" id="r-SiOR5w4PY93gON-Drh">
    <mxGraphModel dx="1348" dy="811" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="583" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\n\nclass Library {\n  + searchBook(title: String): List&lt;Book&gt;\n  + processBorrow(order: Order)\n  + processReturn(book: Book)\n  + reportLoss(book: Book)\n}\n\nclass Member {\n  - id: int\n  - name: String\n  + searchBook()\n  + createOrder()\n  + borrowBook()\n  + returnBook()\n  + payCompensation()\n}\n\nclass Book {\n  - id: int\n  - title: String\n  - author: String\n  - price: double\n  - status: String\n  + getStatus(): String\n  + setStatus(status: String)\n  + getPrice(): double\n}\n\nclass Order {\n  - orderId: int\n  - date: Date\n  - status: String\n  + addBook(book: Book)\n  + confirmOrder()\n}\n\nclass BankAccount {\n  - accountId: String\n  + receivePayment(amount: double)\n}\n\nLibrary \&quot;1\&quot; *-- \&quot;*\&quot; Book : contains &gt;\nMember \&quot;1\&quot; -- \&quot;*\&quot; Order : places &gt;\nOrder \&quot;1\&quot; o-- \&quot;*\&quot; Book : includes &gt;\nMember \&quot;1\&quot; -- \&quot;1\&quot; BankAccount : transfers to &gt;\nLibrary \&quot;1\&quot; -- \&quot;*\&quot; Order : processes &gt;\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="607" width="639" x="120" y="140" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor Member\nparticipant \&quot;lib:Library\&quot; as Library\nparticipant \&quot;order:Order\&quot; as Order\nparticipant \&quot;book:Book\&quot; as Book\nparticipant \&quot;bank:BankAccount\&quot; as BankAccount\n\nMember -&gt; Library: 1. searchBook(query)\nLibrary --&gt; Member: 2. list of books\nMember -&gt; Order **: 3. createOrder()\n\nloop For each selected book\n    Member -&gt; Order: 4. addBook(book)\nend\n\nMember -&gt; Library: 5. processBorrow(order)\nLibrary -&gt; Book: 6. setStatus(\&quot;Borrowed\&quot;)\n\nalt Успішне повернення\n    Member -&gt; Library: 7. processReturn(book)\n    Library -&gt; Book: 8. setStatus(\&quot;Available\&quot;)\nelse Втрата книги\n    Member -&gt; Library: 9. reportLoss(book)\n    Library -&gt; Book: 10. setStatus(\&quot;Lost\&quot;)\n    Library -&gt; Member: 11. requestCompensation(price)\n    Member -&gt; BankAccount: 12. receivePayment(price)\nend\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="600" width="649" x="240" y="806" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nallowmixing\nskinparam rectangle {\n    BackgroundColor White\n    BorderColor Black\n}\n\nrectangle \&quot;: Member\&quot; as Member\nrectangle \&quot;: Library\&quot; as Library\nrectangle \&quot;: Order\&quot; as Order\nrectangle \&quot;: Book\&quot; as Book\nrectangle \&quot;: BankAccount\&quot; as Bank\n\nMember -right-&gt; Library : 1. searchBook()\\n5. processBorrow(order)\\n7. processReturn(book)\\n9. reportLoss(book) &gt;\nLibrary -left-&gt; Member : 2. return book list\\n11. requestCompensation() &gt;\n\nMember -down-&gt; Order : 3. createOrder()\\n4. addBook() &gt;\n\nLibrary -down-&gt; Book : 6. setStatus(\&quot;Borrowed\&quot;)\\n8. setStatus(\&quot;Available\&quot;)\\n10. setStatus(\&quot;Lost\&quot;) &gt;\n\nMember -right-&gt; Bank : 12. receivePayment(price) &gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-4">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="356" width="602" x="889" y="280" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor \&quot;Читач (Member)\&quot; as Member\nparticipant \&quot;Каталог (Catalog)\&quot; as Catalog\nparticipant \&quot;Замовлення (Order)\&quot; as Order\nparticipant \&quot;Бібліотека (Library)\&quot; as Library\nparticipant \&quot;Книга (Book)\&quot; as Book\nparticipant \&quot;Банк (Bank)\&quot; as Bank\n\nautonumber\n\nMember -&gt; Catalog: Знайти книгу (search)\nCatalog --&gt; Member: Список доступних книг\nMember -&gt; Order: Створити замовлення (createOrder)\nOrder -&gt; Book: Додати до замовлення\nMember -&gt; Library: Взяти замовлені книги (borrowOrder)\nLibrary -&gt; Book: Змінити статус на \&quot;Видана\&quot;\n\nalt Звичайне повернення\n    Member -&gt; Library: Повернути книгу (returnBook)\n    Library -&gt; Book: Змінити статус на \&quot;Доступна\&quot;\nelse Втрата книги\n    Member -&gt; Library: Повідомити про втрату (reportLostBook)\n    Library -&gt; Book: Запросити вартість книги (getPrice)\n    Book --&gt; Library: Вартість\n    Library --&gt; Member: Виставити рахунок на компенсацію\n    Member -&gt; Bank: Сплатити вартість (payCompensation)\n    Bank --&gt; Library: Підтвердження успішної оплати\n    Library -&gt; Book: Змінити статус на \&quot;Списана\&quot;\nend\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-5">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="641" width="982" x="640" y="1820" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nskinparam rectangle {\n    BackgroundColor transparent\n    BorderColor transparent\n}\n\nobject \&quot;&lt;u&gt;:Person&lt;/u&gt;\&quot; as Person\nobject \&quot;&lt;u&gt;bank:Bank&lt;/u&gt;\&quot; as Bank\nobject \&quot;&lt;u&gt;customer:Customer&lt;/u&gt;\&quot; as Customer\nobject \&quot;&lt;u&gt;fromAcc:Account&lt;/u&gt;\&quot; as Acc1\nobject \&quot;&lt;u&gt;toAcc:Account&lt;/u&gt;\&quot; as Acc2\n\nPerson --&gt; Bank : 1. registerCustomer()\\n2. createAccount()\\n3. processTransfer()\n\nBank --&gt; Customer : 1.1. &lt;&lt;create&gt;&gt;\nBank --&gt; Acc1 : 2.1. &lt;&lt;create&gt;&gt;\\n3.1. withdraw(amount)\\n3.3. [if error] deposit(amount)\nBank --&gt; Acc2 : 3.2. deposit(amount)\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-6">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="200" width="747" x="1962" y="1590" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nactor Person\nparticipant \&quot;bank: Bank\&quot; as Bank\nparticipant \&quot;customer: Customer\&quot; as Customer\nparticipant \&quot;fromAcc: Account\&quot; as Acc1\nparticipant \&quot;toAcc: Account\&quot; as Acc2\nparticipant \&quot;tx: Transaction\&quot; as Transaction\n\n== 1. Реєстрація клієнта ==\nPerson -&gt; Bank : registerCustomer(name, info)\nactivate Bank\nBank -&gt; Customer ** : create(name, info)\nBank --&gt; Person : customer (ID)\ndeactivate Bank\n\n== 2. Відкриття рахунку ==\nPerson -&gt; Bank : createAccount(customer)\nactivate Bank\nBank -&gt; Acc1 ** : create()\nBank --&gt; Person : accountDetails\ndeactivate Bank\n\n== 3. Операції з рахунком (Переказ) ==\nPerson -&gt; Bank : processTransfer(fromAcc, toAcc, amount)\nactivate Bank\n\nBank -&gt; Acc1 : withdraw(amount)\nactivate Acc1\n\nalt Недостатньо коштів\n    Acc1 --&gt; Bank : false (Error)\n    Bank -&gt; Transaction ** : create(amount, \&quot;Failed: Insufficient Funds\&quot;)\n    Bank --&gt; Person : Помилка: Недостатньо коштів\nelse Коштів достатньо\n    Acc1 --&gt; Bank : true\n    deactivate Acc1\n    \n    Bank -&gt; Acc2 : deposit(amount)\n    activate Acc2\n    alt Помилка в реквізитах (рахунок не знайдено/неактивний)\n        Acc2 --&gt; Bank : false (Error)\n        deactivate Acc2\n        Bank -&gt; Acc1 : deposit(amount) [Повернення коштів]\n        Bank -&gt; Transaction ** : create(amount, \&quot;Failed: Invalid target\&quot;)\n        Bank --&gt; Person : Помилка: Невірні реквізити\n    else Успішне зарахування\n        Acc2 --&gt; Bank : true\n        Bank -&gt; Transaction ** : create(amount, \&quot;Success\&quot;)\n        Bank --&gt; Person : Перерахунок виконано успішно\n    end\nend\n\ndeactivate Bank\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-7">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1011" width="1041" x="1680" y="570" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\n\nclass Person {\n  - name: String\n  - contactInfo: String\n  + getName(): String\n}\n\nclass Customer {\n  - customerId: String\n  + getCustomerId(): String\n}\n\nclass Bank {\n  - name: String\n  + registerCustomer(person: Person): Customer\n  + createAccount(customer: Customer): Account\n  + processTransfer(fromAcc: String, toAcc: String, amount: Double): Transaction\n}\n\nclass Account {\n  - accountNumber: String\n  - balance: Double\n  - status: String\n  + deposit(amount: Double): Boolean\n  + withdraw(amount: Double): Boolean\n  + getBalance(): Double\n}\n\nclass Transaction {\n  - transactionId: String\n  - amount: Double\n  - date: Date\n  - status: String\n  + execute(): void\n  + fail(reason: String): void\n}\n\nPerson &lt;|-- Customer : \&quot;успадковує/стає\&quot;\nBank \&quot;1\&quot; -- \&quot;*\&quot; Customer : \&quot;обслуговує\&quot;\nCustomer \&quot;1\&quot; -- \&quot;*\&quot; Account : \&quot;володіє\&quot;\nBank \&quot;1\&quot; -- \&quot;*\&quot; Account : \&quot;управляє\&quot;\nAccount \&quot;1\&quot; -- \&quot;*\&quot; Transaction : \&quot;має історію\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="0MSKQXbglUyISMLa5iPw-8">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="700" width="752" x="970" y="800" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="r9JU4DQqeBC5abb7b1if-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="60" width="120" x="960" y="70" as="geometry" />
        </mxCell>
        <mxCell id="r9JU4DQqeBC5abb7b1if-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="60" width="120" x="970" y="200" as="geometry" />
        </mxCell>
        <mxCell id="r9JU4DQqeBC5abb7b1if-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="60" width="120" x="1250" y="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
