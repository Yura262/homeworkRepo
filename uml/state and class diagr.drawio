  <diagram id="h_Y7sUj0fOmHnWlE0wPn" name="Сторінка-2">
    <mxGraphModel dx="1195" dy="1217" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="583" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide empty description\nskinparam state {\n    BackgroundColor White\n    BorderColor Black\n    ArrowColor Black\n}\n\ntitle Діаграма станів цифрового диктофона\n\n[*] --&gt; Звичайний_режим : Увімкнення\n\nstate \&quot;Звичайний_режим\&quot; as Active {\n    Active : do/ Відображення поточного часу та дати на екрані\n\n    [*] --&gt; Очікування\n\n    state \&quot;Очікування\&quot; as Idle {\n        Idle : do/ Очікування команд користувача\n    }\n\n    state \&quot;Робота_з_меню\&quot; as Menu {\n        Menu : do/ Відображення пунктів меню та навігація (повідомлення 1-10)\n        Menu : Кнопка \&quot;Так\&quot; [обрано опцію \&quot;Видалити\&quot;] / знищити повідомлення\n    }\n\n    state \&quot;Запис\&quot; as Recording {\n        Recording : entry/ Увімкнути мікрофон\n        Recording : do/ Запис аудіо у пам&#39;ять\n        Recording : do/ Відображення тривалості поточного запису\n        Recording : exit/ Зберегти повідомлення\n    }\n\n    state \&quot;Відтворення\&quot; as Playing {\n        Playing : entry/ Увімкнути гучномовець\n        Playing : do/ Прямий доступ до пам&#39;яті за номером\n        Playing : do/ Відтворення звукового повідомлення\n        Playing : do/ Відображення тривалості відтвореної частини\n        Playing : exit/ Вимкнути гучномовець\n    }\n\n    state \&quot;Пауза_Запису\&quot; as PausedRec {\n        PausedRec : do/ Блимання індикатора запису\n    }\n\n    state \&quot;Пауза_Відтворення\&quot; as PausedPlay {\n        PausedPlay : do/ Блимання індикатора відтворення\n    }\n\n    &#39; Переходи для меню\n    Idle --&gt; Menu : Кнопка \&quot;Стрілка\&quot; / відкрити меню\n    Menu --&gt; Menu : Кнопка \&quot;Стрілка\&quot; / перехід до наступного пункту\n    Menu --&gt; Idle : Кнопка \&quot;Ні\&quot; / скасування та вихід з меню\n\n    &#39; Переходи для запису\n    Idle --&gt; Recording : Кнопка \&quot;Запис\&quot; [кількість повідомлень &lt; 10 AND вільна пам&#39;ять &gt; 0] / ініціалізація запису\n    Menu --&gt; Recording : Кнопка \&quot;Запис\&quot; [кількість повідомлень &lt; 10 AND вільна пам&#39;ять &gt; 0] / ініціалізація запису\n    Recording --&gt; Idle : Кнопка \&quot;Запис\&quot; / зупинити запис\n    Recording --&gt; Idle : [вільна пам&#39;ять вичерпана] / автоматична зупинка\n\n    &#39; Переходи для відтворення\n    Idle --&gt; Playing : Кнопка \&quot;Відтворення\&quot; [обрано повідомлення AND пам&#39;ять не порожня] / старт\n    Menu --&gt; Playing : Кнопка \&quot;Відтворення\&quot; [обрано повідомлення AND пам&#39;ять не порожня] / старт\n    Playing --&gt; Idle : Кнопка \&quot;Відтворення\&quot; / зупинити\n    Playing --&gt; Idle : [досягнуто кінця повідомлення] / автоматична зупинка\n\n    &#39; Переходи для паузи\n    Recording --&gt; PausedRec : Кнопка \&quot;Пауза\&quot; / призупинити\n    PausedRec --&gt; Recording : Кнопка \&quot;Пауза\&quot; або \&quot;Запис\&quot; / продовжити\n    PausedRec --&gt; Idle : Кнопка \&quot;Ні\&quot; / скасувати і зберегти\n\n    Playing --&gt; PausedPlay : Кнопка \&quot;Пауза\&quot; / призупинити\n    PausedPlay --&gt; Playing : Кнопка \&quot;Пауза\&quot; або \&quot;Відтворення\&quot; / продовжити\n    PausedPlay --&gt; Idle : Кнопка \&quot;Ні\&quot; / зупинити\n}\n\nstate \&quot;Режим_заощадження_енергії\&quot; as PowerSaving {\n    PowerSaving : entry/ Вимкнення дисплея та периферії\n    PowerSaving : do/ Моніторинг рівня заряду батареї\n    PowerSaving : do/ Очікування переривання від кнопок\n}\n\n&#39; Глобальні переходи між основним режимом та енергозбереженням\nActive --&gt; PowerSaving : [заряд батареї &lt; встановленої межі] / примусовий сон\nActive --&gt; PowerSaving : after(30s) [відсутня взаємодія користувача] / перехід у сон\nPowerSaving --&gt; Active : Натискання будь-якої кнопки [заряд батареї &gt;= встановленої межі] / пробудження\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="uPR6oDTSwwIp7VXPu0Ic-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="675" width="3655" x="930" y="190" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="hdF3gt5ipycoQKfelF9J" name="Сторінка-3">
    <mxGraphModel dx="1155" dy="695" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="583" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide empty description\nskinparam state {\n  BackgroundColor LightFading\n  BorderColor DarkSlateGray\n  ArrowColor Black\n}\n\ntitle Діаграма станів цифрового диктофона\n\n[*] --&gt; CheckingBatteryInitial\n\nstate CheckingBatteryInitial &lt;&lt;choice&gt;&gt;\nCheckingBatteryInitial --&gt; NormalMode : [Заряд в нормі]\nCheckingBatteryInitial --&gt; PowerSaveMode : [Заряд нижче межі]\n\nstate NormalMode {\n  [*] --&gt; Idle\n  \n  state Idle {\n    Idle : entry / увімкнути екран\n    Idle : do / відображати поточний час і дату\n  }\n  \n  state MenuNavigation {\n    MenuNavigation : do / підсвічувати пункти меню та номери повідомлень (1-10)\n  }\n  \n  state RecordingMode {\n    state CheckingMemory &lt;&lt;choice&gt;&gt;\n    [*] --&gt; CheckingMemory\n    \n    CheckingMemory --&gt; Recording : [Пам&#39;ять доступна AND повідомлень &lt; 10]\n    CheckingMemory --&gt; ErrorState : [Пам&#39;ять заповнена OR повідомлень = 10]\n    \n    state Recording {\n      Recording : entry / активувати вбудований мікрофон\n      Recording : do / запис звуку; відображати тривалість запису\n      Recording : exit / зберегти повідомлення в пам&#39;ять\n    }\n    \n    state PausedRecording {\n      PausedRecording : do / відображати індикатор паузи\n    }\n    \n    state ErrorState {\n      ErrorState : do / відображати повідомлення про помилку пам&#39;яті\n    }\n    \n    Recording --&gt; PausedRecording : Натиснуто \&quot;Пауза\&quot;\n    PausedRecording --&gt; Recording : Натиснуто \&quot;Запис\&quot; або \&quot;Пауза\&quot;\n    Recording --&gt; [*] : Натиснуто \&quot;Ні\&quot; (скасування/стоп)\n    ErrorState --&gt; [*] : Натиснуто \&quot;Так\&quot; або \&quot;Ні\&quot;\n  }\n  \n  state PlaybackMode {\n    state CheckingMessageExistence &lt;&lt;choice&gt;&gt;\n    [*] --&gt; CheckingMessageExistence\n    \n    CheckingMessageExistence --&gt; Playback : [Повідомлення існує]\n    CheckingMessageExistence --&gt; [*] : [Повідомлення порожнє]\n    \n    state Playback {\n      Playback : entry / активувати гучномовець\n      Playback : do / відтворювати мову; відображати тривалість відтвореної частини\n      Playback : exit / вимкнути гучномовець\n    }\n    \n    state PausedPlayback {\n      PausedPlayback : do / відображати час на паузі\n    }\n    \n    Playback --&gt; PausedPlayback : Натиснуто \&quot;Пауза\&quot;\n    PausedPlayback --&gt; Playback : Натиснуто \&quot;Відтворення\&quot;\n    Playback --&gt; [*] : Завершення повідомлення або натиснуто \&quot;Ні\&quot;\n  }\n  \n  state DeletingMessage {\n    [*] --&gt; ConfirmDeletion\n    \n    state ConfirmDeletion {\n      ConfirmDeletion : do / відображати запит \&quot;Видалити повідомлення?\&quot;\n    }\n    \n    state Deleting {\n      Deleting : entry / видалити файл з пам&#39;яті\n      Deleting : do / відображати \&quot;Видалення...\&quot;\n    }\n    \n    ConfirmDeletion --&gt; Deleting : Натиснуто \&quot;Так\&quot;\n    ConfirmDeletion --&gt; [*] : Натиснуто \&quot;Ні\&quot; [Скасування]\n    Deleting --&gt; [*] : Завершення видалення\n  }\n  \n  &#39; Переходи всередині NormalMode\n  Idle --&gt; MenuNavigation : Натиснуто стрілки\n  MenuNavigation --&gt; Idle : Натиснуто \&quot;Ні\&quot; (повернення)\n  \n  Idle --&gt; RecordingMode : Натиснуто \&quot;Запис\&quot;\n  MenuNavigation --&gt; RecordingMode : Натиснуто \&quot;Запис\&quot;\n  RecordingMode --&gt; Idle : Завершення процесу\n  \n  MenuNavigation --&gt; PlaybackMode : Натиснуто \&quot;Відтворення\&quot; [Обрано повідомлення]\n  PlaybackMode --&gt; Idle : Завершення процесу\n  \n  MenuNavigation --&gt; DeletingMessage : Вибрано опцію видалення\n  DeletingMessage --&gt; Idle : Завершення процесу\n}\n\nstate PowerSaveMode {\n  PowerSaveMode : entry / вимкнути екран, мікрофон, гучномовець\n  PowerSaveMode : do / мінімальне споживання, моніторинг кнопок та рівня заряду\n}\n\n&#39; Глобальні переходи для керування живленням\nNormalMode --&gt; PowerSaveMode : [Бездіяльність 30 секунд]\nNormalMode --&gt; PowerSaveMode : [Падіння заряду нижче встановленої межі]\n\nstate WakeUpCheck &lt;&lt;choice&gt;&gt;\nPowerSaveMode --&gt; WakeUpCheck : Натиснуто будь-яку кнопку\nWakeUpCheck --&gt; NormalMode : [Нормальний рівень заряду батарей]\nWakeUpCheck --&gt; PowerSaveMode : [Заряд нижче межі]\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tYtVwVU7McvUtr8mOij3-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1132" width="2337" x="260" y="470" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
